{
    "name": "poc-frontend",
    "private": true,
    "version": "0.1.0",
    "scripts": {
        "dev": "ng serve --host 0.0.0.0 --port 5173",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "jest",
        "lint": "eslint \"src/**/*.{ts,html}\"",
        "typecheck": "tsc -p tsconfig.app.json --noEmit",
        "openapi:generate": "orval --config ./orval.config.ts && node scripts/write-generated-readme.mjs",
        "openapi:check": "npm run openapi:generate && git diff --exit-code -- src/api/generated"
    },
    "dependencies": {
        "@angular/common": "^21.2.0",
        "@angular/compiler": "^21.2.0",
        "@angular/core": "^21.2.0",
        "@angular/forms": "^21.2.0",
        "@angular/platform-browser": "^21.2.0",
        "@angular/router": "^21.2.0",
        "@lucide/angular": "^1.21.0",
        "rxjs": "^7.8.2",
        "tslib": "^2.8.1",
        "zone.js": "~0.15.1"
    },
    "devDependencies": {
        "@angular/build": "^21.2.0",
        "@angular/cli": "^21.2.0",
        "@angular/compiler-cli": "^21.2.0",
        "@types/jest": "^30.0.0",
        "angular-eslint": "^21.4.0",
        "eslint": "^9.20.0",
        "glob": "^13.0.6",
        "jest": "^30.0.0",
        "jest-preset-angular": "^17.0.0",
        "jsdom": "^29.1.1",
        "orval": "^8.18.0",
        "test-exclude": "^8.0.0",
        "typescript": "~5.9.2",
        "typescript-eslint": "^8.24.0"
    }
}
