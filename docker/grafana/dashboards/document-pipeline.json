{
  "uid": "poc-document-pipeline",
  "title": "Document Pipeline",
  "tags": ["alittlebyte", "pipeline"],
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "row",
      "title": "Sintesi pipeline",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "type": "stat",
      "title": "Documenti completati",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [{ "refId": "A", "expr": "sum(poc_original_documents_total{status=\"completed\"})", "instant": true, "legendFormat": "completati" }]
    },
    {
      "type": "stat",
      "title": "In elaborazione",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [{ "refId": "A", "expr": "sum(poc_original_documents_total{status=\"processing\"})", "instant": true, "legendFormat": "in corso" }]
    },
    {
      "type": "stat",
      "title": "Documenti falliti",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "refId": "A", "expr": "sum(poc_original_documents_total{status=\"failed\"})", "instant": true, "legendFormat": "falliti" }]
    },
    {
      "type": "stat",
      "title": "Bloccati oltre timeout",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "refId": "A", "expr": "sum(poc_document_stuck_processing_total)", "instant": true, "legendFormat": "bloccati" }]
    },
    {
      "type": "table",
      "title": "Documenti per stato",
      "gridPos": { "x": 0, "y": 5, "w": 8, "h": 9 },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [{ "refId": "A", "expr": "sum by (status) (poc_original_documents_total)", "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "status": "Stato", "Value": "Documenti" } } },
        { "id": "sortBy", "options": { "fields": "", "sort": [{ "field": "Documenti", "desc": true }] } }
      ]
    },
    {
      "type": "table",
      "title": "Step di elaborazione (coda SQS)",
      "gridPos": { "x": 8, "y": 5, "w": 8, "h": 9 },
      "fieldConfig": { "defaults": {}, "overrides": [{ "matcher": { "id": "byName", "options": "Falliti" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }] }] },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [
        { "refId": "A", "expr": "sum by (task_type) (poc_sqs_messages_received_total)", "instant": true, "format": "table" },
        { "refId": "B", "expr": "sum by (task_type) (poc_sqs_messages_failed_total)", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "task_type": "Step", "Value #A": "Ricevuti", "Value #B": "Falliti" } } }
      ]
    },
    {
      "type": "table",
      "title": "Fallimenti Step Functions per motivo",
      "gridPos": { "x": 16, "y": 5, "w": 8, "h": 9 },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [{ "refId": "A", "expr": "sum by (reason) (poc_stepfunctions_executions_failed_total)", "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "reason": "Motivo", "Value": "Conteggio" } } },
        { "id": "sortBy", "options": { "fields": "", "sort": [{ "field": "Conteggio", "desc": true }] } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Esecuzioni Step Functions (rate 5m)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(poc_stepfunctions_executions_started_total[5m]))", "legendFormat": "avviate" },
        { "refId": "B", "expr": "sum(rate(poc_stepfunctions_executions_failed_total[5m]))", "legendFormat": "fallite" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Throughput step pipeline (rate 5m)",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" } },
      "targets": [
        { "refId": "A", "expr": "sum by (task_type) (rate(poc_sqs_messages_received_total[5m]))", "legendFormat": "ricevuti {{task_type}}" },
        { "refId": "B", "expr": "sum by (task_type) (rate(poc_sqs_messages_failed_total[5m]))", "legendFormat": "falliti {{task_type}}" }
      ]
    },
    {
      "type": "row",
      "title": "Log di elaborazione",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 }
    },
    {
      "type": "logs",
      "title": "Errori pipeline (container queue + app)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 11 },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [{ "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "{project=\"poc\", service=~\"queue|app\"} |~ \"(?i)level_name.{0,6}(error|critical|emergency)\"", "maxLines": 200 }]
    }
  ]
}
