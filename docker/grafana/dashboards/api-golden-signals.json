{
  "uid": "poc-api-golden-signals",
  "title": "API Golden Signals",
  "tags": ["alittlebyte", "api", "sre"],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "row",
      "title": "Segnali d'oro (latency, traffic, errors)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "type": "stat",
      "title": "Traffico",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [{ "refId": "A", "expr": "sum(rate(poc_http_requests_total[5m]))", "instant": true, "legendFormat": "req/s" }]
    },
    {
      "type": "stat",
      "title": "Tasso di errore (5xx)",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "refId": "A", "expr": "sum(rate(poc_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(poc_http_requests_total[5m])), 1)", "instant": true, "legendFormat": "5xx" }]
    },
    {
      "type": "stat",
      "title": "Latenza p95",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [{ "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(poc_http_request_duration_seconds_bucket[5m])) by (le))", "instant": true, "legendFormat": "p95" }]
    },
    {
      "type": "stat",
      "title": "Latenza p99",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 2 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [{ "refId": "A", "expr": "histogram_quantile(0.99, sum(rate(poc_http_request_duration_seconds_bucket[5m])) by (le))", "instant": true, "legendFormat": "p99" }]
    },
    {
      "type": "timeseries",
      "title": "Richieste per classe di stato (rate 5m)",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } }, "unit": "reqps" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(poc_http_requests_total{status=~\"2..\"}[5m]))", "legendFormat": "2xx" },
        { "refId": "B", "expr": "sum(rate(poc_http_requests_total{status=~\"4..\"}[5m]))", "legendFormat": "4xx" },
        { "refId": "C", "expr": "sum(rate(poc_http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latenza (quantili)",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(poc_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(poc_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(poc_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "table",
      "title": "Endpoint - golden signals per route",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 9 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Req/s" }, "properties": [{ "id": "unit", "value": "reqps" }, { "id": "decimals", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "Errori/s (5xx)" }, "properties": [{ "id": "unit", "value": "reqps" }, { "id": "decimals", "value": 3 }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.0001 }] } }] },
          { "matcher": { "id": "byName", "options": "p95 (s)" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 3 }] }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [
        { "refId": "A", "expr": "sum by (route) (rate(poc_http_requests_total[5m]))", "instant": true, "format": "table" },
        { "refId": "B", "expr": "sum by (route) (rate(poc_http_requests_total{status=~\"5..\"}[5m]))", "instant": true, "format": "table" },
        { "refId": "C", "expr": "histogram_quantile(0.95, sum by (route, le) (rate(poc_http_request_duration_seconds_bucket[5m])))", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "route": "Route", "Value #A": "Req/s", "Value #B": "Errori/s (5xx)", "Value #C": "p95 (s)" } } },
        { "id": "sortBy", "options": { "fields": "", "sort": [{ "field": "Req/s", "desc": true }] } }
      ]
    }
  ]
}
