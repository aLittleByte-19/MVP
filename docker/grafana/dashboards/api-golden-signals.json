{
  "uid": "poc-api-golden-signals",
  "title": "API Golden Signals",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum(rate(poc_http_requests_total[5m])) by (route)", "legendFormat": "{{route}}" }]
    },
    {
      "type": "timeseries",
      "title": "Error rate",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum(rate(poc_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(poc_http_requests_total[5m])), 1)", "legendFormat": "5xx ratio" }]
    },
    {
      "type": "timeseries",
      "title": "p95 latency",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(poc_http_request_duration_seconds_bucket[5m])) by (le, route))", "legendFormat": "{{route}}" }]
    },
    {
      "type": "table",
      "title": "Top endpoint",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "topk(10, sum(rate(poc_http_requests_total[5m])) by (route, method, status))", "format": "table" }]
    }
  ]
}
