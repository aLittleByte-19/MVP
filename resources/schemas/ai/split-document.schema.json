{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://poc.alittlebyte.local/schemas/ai/split-document.schema.json",
    "title": "SplitDocumentResult",
    "description": "Per-employee page boundaries returned by the Bedrock document classifier. An empty array is a valid model answer (no distinct employees) handled as business rule downstream; extra keys per segment are ignored.",
    "type": "array",
    "maxItems": 50,
    "items": {
        "type": "object",
        "required": ["employee_name", "start_page", "end_page"],
        "properties": {
            "employee_name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200
            },
            "start_page": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10000
            },
            "end_page": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10000
            }
        }
    }
}
