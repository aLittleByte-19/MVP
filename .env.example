# =============================================================================
#  NEXUM PoC — bootstrap locale (Docker Compose + LocalStack)
# =============================================================================
#  Due livelli di configurazione:
#   1) Variabili lette da Docker Compose → passate a Terraform, che le scrive in
#      SSM Parameter Store / Secrets Manager (è la fonte runtime di default).
#   2) Con CONFIG_SOURCE=env l'app legge invece direttamente da queste variabili
#      (utile per test/dev senza SSM). Per questo molte chiavi sono duplicate sui
#      due livelli: vanno tenute allineate.
#
#  REGOLE DI FORMATTAZIONE (importanti):
#   - Niente commenti in coda al valore: vanno su righe proprie (sopra la chiave).
#     Un commento inline può finire dentro il valore e rompere Terraform/Make.
#   - I campi numerici (porte, *_MAX_*, timeout) devono avere un numero: mai vuoti.
#
#  AWS reale: dopo ogni modifica alle AWS_REAL_* esegui  `make refresh-runtime`
#  (riscrive SSM/Secrets e ricrea app+queue).
# =============================================================================


# -----------------------------------------------------------------------------
#  Caricamento configurazione runtime (bootstrap Laravel)
# -----------------------------------------------------------------------------
#  CONFIG_SOURCE: 'aws' = carica da SSM/Secrets (default); 'env' = da questo file.
#  CONFIG_AWS_REGION è la region usata SOLO per leggere SSM/Secrets da LocalStack.
CONFIG_SOURCE=aws
CONFIG_SSM_PATH=/poc/app
CONFIG_SECRET_IDS=/poc/app/runtime
CONFIG_AWS_ENDPOINT=http://localstack:4566
CONFIG_AWS_REGION=eu-north-1
CONFIG_AWS_ACCESS_KEY_ID=test
CONFIG_AWS_SECRET_ACCESS_KEY=test
CONFIG_AWS_SESSION_TOKEN=


# -----------------------------------------------------------------------------
#  LocalStack (AWS emulato in locale)
# -----------------------------------------------------------------------------
#  Le credenziali qui sotto sono fittizie ('test'): NON sono segreti reali.
#  ENDPOINT_INTERNAL = visto dai container; ENDPOINT_EXTERNAL = visto dall'host.
LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=0
LOCALSTACK_ENDPOINT_INTERNAL=http://localstack:4566
LOCALSTACK_ENDPOINT_EXTERNAL=http://localhost:4566
LOCALSTACK_AWS_ACCESS_KEY_ID=test
LOCALSTACK_AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_AWS_SESSION_TOKEN=


# -----------------------------------------------------------------------------
#  Porte pubblicate sull'host (lato sinistro = porta sulla tua macchina)
# -----------------------------------------------------------------------------
TRAEFIK_WEB_PORT=8080
TRAEFIK_WEBSECURE_PORT=8443
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
TEMPO_PORT=3200
REDIS_PORT=6379


# -----------------------------------------------------------------------------
#  Build immagine applicativa
# -----------------------------------------------------------------------------
#  true = installa anche le dipendenze dev (test/pint/phpstan). false in prod.
COMPOSER_INSTALL_DEV=true


# -----------------------------------------------------------------------------
#  Observability — OpenTelemetry Collector
# -----------------------------------------------------------------------------
OTEL_SERVICE_NAMESPACE=alittlebyte
OTEL_SERVICE_NAME=poc-document-pipeline
OTEL_DEPLOYMENT_ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318


# -----------------------------------------------------------------------------
#  Grafana
# -----------------------------------------------------------------------------
#  SICUREZZA: cambia GRAFANA_ADMIN_PASSWORD se esponi Grafana fuori da localhost.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin


# -----------------------------------------------------------------------------
#  Applicazione (POC_*)
# -----------------------------------------------------------------------------
#  POC_AWS_DEFAULT_REGION alimenta Terraform (region delle risorse LocalStack).
POC_RELEASE_VERSION=local
POC_METRICS_ENABLED=true
POC_AWS_DEFAULT_REGION=eu-north-1
POC_APP_URL=https://localhost:8443


# -----------------------------------------------------------------------------
#  Database PostgreSQL
# -----------------------------------------------------------------------------
POC_DB_DATABASE=poc
POC_DB_USERNAME=poc
POC_DB_PASSWORD=poc-local-password


# -----------------------------------------------------------------------------
#  Elaborazione documenti & AI (parametri pipeline)
# -----------------------------------------------------------------------------
#  POC_BEDROCK_MODEL_ID alimenta Terraform→SSM (valore usato dalla pipeline).
#  Tienilo allineato a BEDROCK_MODEL_ID più in basso (usato con CONFIG_SOURCE=env).
#  POC_DOCUMENT_DISK: 's3' = bucket LocalStack; 'real_s3' = bucket S3 reale.
POC_BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
POC_CONFIDENCE_THRESHOLD=80
FILESYSTEM_DISK=s3
POC_DOCUMENT_DISK=s3
POC_MAX_UPLOAD_MB=20
POC_MAX_PDF_PAGES=50
POC_PROCESSING_TIMEOUT_SECONDS=600


# -----------------------------------------------------------------------------
#  Identità locale (mock — usata in POC_IDENTITY_MODE=local)
# -----------------------------------------------------------------------------
POC_IDENTITY_MODE=local
POC_LOCAL_USER_ID=poc-local-user
POC_LOCAL_USER_EMAIL=operator@alittlebyte.local
POC_LOCAL_USER_NAME=Alittlebyte Operator
POC_LOCAL_TENANT_ID=poc-local-tenant
POC_LOCAL_ROLES=poc-operator


# -----------------------------------------------------------------------------
#  Orchestrazione workflow su LocalStack (valori diretti, path CONFIG_SOURCE=env)
# -----------------------------------------------------------------------------
#  AWS_DEFAULT_REGION = region di default dei client SDK quando l'app legge da env.
#  ARN/URL vuoti vengono popolati da Terraform in SSM (non riempirli a mano).
#  SQS_PREFIX in formato LocalStack: <endpoint>/<account-id>.
AWS_DEFAULT_REGION=eu-north-1
AWS_BUCKET=poc-documents-local
AWS_ENDPOINT=http://localstack:4566
AWS_USE_PATH_STYLE_ENDPOINT=true
WORKFLOW_DRIVER=localstack
STEPFUNCTIONS_ENDPOINT=http://localstack:4566
DOCUMENT_PIPELINE_STATE_MACHINE_ARN=
DOCUMENT_PIPELINE_TASK_QUEUE_URL=
SQS_ENDPOINT=http://localstack:4566
SQS_PREFIX=http://localstack:4566/000000000000
SQS_QUEUE=poc-documents
SQS_DLQ_URL=
POC_WORKFLOW_SQS_WAIT_SECONDS=10
POC_WORKFLOW_SQS_MAX_MESSAGES=5


# =============================================================================
#  AWS REALE (opzionale) — S3 / Textract / Bedrock su account vero
# =============================================================================
#  Vuoto = tutto su LocalStack. NON committare valori reali.
#  Attivazione: POC_DOCUMENT_DISK=real_s3 (S3) e/o TEXTRACT_ENABLED=true.
#  Dopo ogni modifica qui sotto:  make refresh-runtime
# -----------------------------------------------------------------------------

# --- SEGRETI: credenziali CONDIVISE da S3 + Textract + Bedrock ---------------
#  Un solo IAM principal per i tre servizi. Permessi richiesti su quell'identità:
#    s3:GetObject / s3:PutObject / s3:ListBucket  +  textract:*  +  bedrock:InvokeModel
#  IAM user (chiavi long-term): lascia AWS_REAL_SESSION_TOKEN vuoto.
#  Credenziali STS/SSO temporanee: compila anche il token (scadono).
#  NB: un ruolo "Bedrock-only" NON basta per S3/Textract.
AWS_REAL_ACCESS_KEY_ID=
AWS_REAL_SECRET_ACCESS_KEY=
AWS_REAL_SESSION_TOKEN=

# --- S3 reale (storage documenti) — attiva con POC_DOCUMENT_DISK=real_s3 -----
#  AWS_REAL_REGION = region del bucket (esempio: eu-central-1).
#  AWS_REAL_S3_BUCKET = nome bucket (esempio: alittlebyte-bucket).
AWS_REAL_REGION=
AWS_REAL_S3_BUCKET=
AWS_REAL_S3_PREFIX=documents/

# --- Textract (OCR) — attiva con TEXTRACT_ENABLED=true -----------------------
#  VINCOLO AWS: Textract legge da S3 e deve stare nella STESSA region del bucket,
#  quindi TEXTRACT_REGION deve combaciare con AWS_REAL_REGION.
#  TEXTRACT_MAX_PAGES / TEXTRACT_MAX_BYTES sono NUMERI: 0 = nessun limite (mai vuoti).
TEXTRACT_ENABLED=false
TEXTRACT_REGION=
TEXTRACT_POLL_INTERVAL_SECONDS=5
TEXTRACT_TIMEOUT_SECONDS=300
TEXTRACT_MAX_PAGES=0
TEXTRACT_MAX_BYTES=0

# --- Bedrock (AI generazione/estrazione) -------------------------------------
#  Sempre abilitato; LocalStack non lo emula, quindi anche in dev servono le
#  AWS_REAL_* sopra + accesso al modello abilitato nella console della region.
#  BEDROCK_REGION = region dove il modello è ACTIVE (esempio: eu-north-1).
#  BEDROCK_ENDPOINT vuoto = endpoint AWS gestito.
#  BEDROCK_MODEL_ID: tienilo allineato a POC_BEDROCK_MODEL_ID più in alto.
BEDROCK_ENABLED=true
BEDROCK_REGION=
BEDROCK_ENDPOINT=
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0