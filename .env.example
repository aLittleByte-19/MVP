# Bootstrap locale per Docker Compose e LocalStack.
# I valori applicativi runtime sono creati da Terraform in SSM Parameter Store
# e Secrets Manager, poi caricati dal bootstrap Laravel.

CONFIG_SOURCE=aws
CONFIG_SSM_PATH=/poc/app
CONFIG_SECRET_IDS=/poc/app/runtime
CONFIG_AWS_ENDPOINT=http://localstack:4566
CONFIG_AWS_REGION=eu-north-1
CONFIG_AWS_ACCESS_KEY_ID=test
CONFIG_AWS_SECRET_ACCESS_KEY=test
CONFIG_AWS_SESSION_TOKEN=

LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=0
LOCALSTACK_ENDPOINT_INTERNAL=http://localstack:4566
LOCALSTACK_ENDPOINT_EXTERNAL=http://localhost:4566
LOCALSTACK_AWS_ACCESS_KEY_ID=test
LOCALSTACK_AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_AWS_SESSION_TOKEN=

TRAEFIK_WEB_PORT=8080
TRAEFIK_WEBSECURE_PORT=8443
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
TEMPO_PORT=3200
POSTGRES_PORT=5432
REDIS_PORT=6379
COMPOSER_INSTALL_DEV=true

OTEL_SERVICE_NAMESPACE=alittlebyte
OTEL_SERVICE_NAME=poc-document-pipeline
OTEL_DEPLOYMENT_ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

POC_RELEASE_VERSION=local
POC_METRICS_ENABLED=true
POC_AWS_DEFAULT_REGION=eu-north-1
POC_APP_URL=https://localhost:8443
POC_DB_DATABASE=poc
POC_DB_USERNAME=poc
POC_DB_PASSWORD=poc-local-password
POC_BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
POC_CONFIDENCE_THRESHOLD=80
FILESYSTEM_DISK=s3
POC_DOCUMENT_DISK=s3
# Use POC_DOCUMENT_DISK=real_s3 with AWS_REAL_* for real Textract validation.
POC_MAX_UPLOAD_MB=20
POC_MAX_PDF_PAGES=50
POC_PROCESSING_TIMEOUT_SECONDS=600
POC_IDENTITY_MODE=local
POC_LOCAL_USER_ID=poc-local-user
POC_LOCAL_USER_EMAIL=operator@alittlebyte.local
POC_LOCAL_USER_NAME=Alittlebyte Operator
POC_LOCAL_TENANT_ID=poc-local-tenant
POC_LOCAL_ROLES=poc-operator

# LocalStack workflow orchestration.
AWS_DEFAULT_REGION=eu-north-1
AWS_BUCKET=poc-documents-local
AWS_ENDPOINT=http://localstack:4566
AWS_USE_PATH_STYLE_ENDPOINT=true
WORKFLOW_DRIVER=localstack
STEPFUNCTIONS_ENDPOINT=http://localstack:4566
DOCUMENT_PIPELINE_STATE_MACHINE_ARN=
DOCUMENT_PIPELINE_TASK_QUEUE_URL=
SQS_ENDPOINT=http://localstack:4566
SQS_PREFIX=http://localstack:4566/000000000000
SQS_QUEUE=poc-documents
SQS_DLQ_URL=
POC_WORKFLOW_SQS_WAIT_SECONDS=10
POC_WORKFLOW_SQS_MAX_MESSAGES=5

# AWS reale opzionale per smoke OCR/AI. Non committare valori reali.
AWS_REAL_REGION=
AWS_REAL_ACCESS_KEY_ID=
AWS_REAL_SECRET_ACCESS_KEY=
AWS_REAL_SESSION_TOKEN=
AWS_REAL_S3_BUCKET=
AWS_REAL_S3_PREFIX=documents/

# Textract reale, disabilitato nei test e nello smoke standard.
TEXTRACT_ENABLED=false
TEXTRACT_REGION=
TEXTRACT_POLL_INTERVAL_SECONDS=5
TEXTRACT_TIMEOUT_SECONDS=300
TEXTRACT_MAX_PAGES=
TEXTRACT_MAX_BYTES=

# Bedrock reale.
BEDROCK_ENABLED=true
BEDROCK_REGION=
BEDROCK_ENDPOINT=
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
